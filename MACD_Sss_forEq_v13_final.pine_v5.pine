//@version=5
indicator("MACD_Sss_forEq v13", shorttitle="MACD_Sss_forEq", overlay=false, max_lines_count=500, max_labels_count=500)

// ============================================================================
// 1) Core MACD inputs
// ============================================================================
fastLen     = input.int(12, "Fast Length", minval=1, group="1. MACD")
slowLen     = input.int(26, "Slow Length", minval=1, group="1. MACD")
signalLen   = input.int(9, "Signal Smoothing", minval=1, group="1. MACD")
src         = input.source(close, "Source", group="1. MACD")

// 金叉/死叉
showCrossDots = input.bool(true, "Show Golden/Dead Cross Dots", group="1. MACD")

// ============================================================================
// 2) Signal-line warning enhancement (dynamic OB/OS structure)
// ============================================================================
warnLookback    = input.int(100, "Lookback", minval=20, group="2. Signal Warning Zone")
warnSensitivity = input.float(1.4, "Sensitivity (Z-score threshold)", minval=0.1, step=0.1, group="2. Signal Warning Zone")
warnSmoothing   = input.int(5, "Signal Smoothing (for warning)", minval=1, group="2. Signal Warning Zone")
showBgWarning   = input.bool(true, "Show subtle background warning", group="2. Signal Warning Zone")

// ============================================================================
// 3) Histogram divergence detection inputs
// ============================================================================
leftBars      = input.int(5, "Left Bars", minval=1, group="3. Histogram Divergence")
rightBars     = input.int(5, "Right Bars", minval=1, group="3. Histogram Divergence")
minDivDist    = input.int(8, "Min Divergence Distance (bars)", minval=1, group="3. Histogram Divergence")
showBullDiv   = input.bool(true, "Show Bullish Divergence", group="3. Histogram Divergence")
showBearDiv   = input.bool(true, "Show Bearish Divergence", group="3. Histogram Divergence")

// 连续高亮段：基础参数（不同周期会再做微调）
divPreBars    = input.int(3, "Divergence Highlight Pre-Bars", minval=0, maxval=8, group="3. Histogram Divergence")
divPostBars   = input.int(5, "Divergence Highlight Post-Bars", minval=1, maxval=12, group="3. Histogram Divergence")
divLineWidth  = input.int(5, "Divergence Highlight Width", minval=2, maxval=10, group="3. Histogram Divergence")

// ============================================================================
// MACD calculations
// ============================================================================
fastMA      = ta.ema(src, fastLen)
slowMA      = ta.ema(src, slowLen)
macdLine    = fastMA - slowMA
signalLine  = ta.ema(macdLine, signalLen)
hist        = macdLine - signalLine

// ============================================================================
// Dynamic warning logic on signal line (statistical zone)
// ============================================================================
sigSmoothed = ta.ema(signalLine, warnSmoothing)
sigMean     = ta.sma(sigSmoothed, warnLookback)
sigStd      = ta.stdev(sigSmoothed, warnLookback)
zScore      = sigStd != 0.0 ? (sigSmoothed - sigMean) / sigStd : 0.0

overboughtWarning = zScore > warnSensitivity
oversoldWarning   = zScore < -warnSensitivity

// ============================================================================
// Timeframe-specific tuning
// 15m: 稍微放慢一点
// 1h : 更早预警
// 4h : 更稳、更宽，但这版比之前收紧一档
// ============================================================================
is15m = timeframe.period == "15"
is1h  = timeframe.period == "60"
is4h  = timeframe.period == "240"

// 15m 略慢；1h 略早；4h 更稳
effectiveMinDivDist = is15m ? minDivDist + 1 : is1h ? math.max(4, minDivDist - 3) : is4h ? math.max(10, minDivDist + 2) : minDivDist

// 价格容差：1h 保持；4h 收紧一档
highTolerance = is1h ? 0.998 : is4h ? 0.997 : 1.0
lowTolerance  = is1h ? 1.002 : is4h ? 1.003 : 1.0

// histogram 衰减/抬升阈值：1h 更激进；4h 比之前更稳
histWeakRatio = is1h ? 0.95 : is4h ? 0.98 : 1.0
histLiftRatio = is1h ? 1.05 : is4h ? 1.02 : 1.0

// 染色长度：15m 稍微缩一点提前量；4h 拉长一点
preBars  = is15m ? math.max(1, divPreBars - 1) : is4h ? divPreBars + 1 : divPreBars
postBars = is4h ? divPostBars + 1 : divPostBars

// ============================================================================
// Divergence detection using confirmed pivots (histogram-only)
// ============================================================================
pl = ta.pivotlow(low, leftBars, rightBars)
ph = ta.pivothigh(high, leftBars, rightBars)

var float prevLowPrice   = na
var float prevLowHist    = na
var int   prevLowIndex   = na

var float prevHighPrice  = na
var float prevHighHist   = na
var int   prevHighIndex  = na

bullDiv = false
bearDiv = false

if not na(pl)
    currLowPrice = low[rightBars]
    currLowHist  = hist[rightBars]
    currLowIndex = bar_index - rightBars

    enoughDist = na(prevLowIndex) ? false : (currLowIndex - prevLowIndex >= effectiveMinDivDist)

    // 基础经典逻辑
    classicBull = currLowPrice < prevLowPrice and currLowHist > prevLowHist

    // 1h / 4h 预警增强
    earlyBullHTF = (currLowPrice <= prevLowPrice * lowTolerance and currLowHist > prevLowHist) or
                   (currLowHist > prevLowHist * histLiftRatio)

    bullDiv := showBullDiv and enoughDist and ((is1h or is4h) ? earlyBullHTF : classicBull)

    prevLowPrice := currLowPrice
    prevLowHist  := currLowHist
    prevLowIndex := currLowIndex

if not na(ph)
    currHighPrice = high[rightBars]
    currHighHist  = hist[rightBars]
    currHighIndex = bar_index - rightBars

    enoughDistH = na(prevHighIndex) ? false : (currHighIndex - prevHighIndex >= effectiveMinDivDist)

    // 基础经典逻辑
    classicBear = currHighPrice >= prevHighPrice and currHighHist < prevHighHist

    // 1h / 4h 预警增强
    earlyBearHTF = (currHighPrice >= prevHighPrice * highTolerance and currHighHist < prevHighHist) or
                   (currHighHist < prevHighHist * histWeakRatio)

    bearDiv := showBearDiv and enoughDistH and ((is1h or is4h) ? earlyBearHTF : classicBear)

    prevHighPrice := currHighPrice
    prevHighHist  := currHighHist
    prevHighIndex := currHighIndex

// ============================================================================
// Visuals
// ============================================================================
histUpStrong   = hist >= 0 and hist > hist[1]
histUpWeak     = hist >= 0 and hist <= hist[1]
histDownStrong = hist < 0 and hist < hist[1]

histColor = color.new(#B07A28, 10)
if histUpStrong
    histColor := color.new(#2CA84A, 0)
else if histUpWeak
    histColor := color.new(#2E55B8, 10)
else if histDownStrong
    histColor := color.new(#FF3B5F, 0)

plot(hist, "Histogram", style=plot.style_columns, color=histColor, linewidth=2)
plot(signalLine, "Signal Line", color=color.new(color.white, 25), linewidth=2)
plot(macdLine, "MACD Line", color=color.new(#F57C00, 0), linewidth=2)
hline(0, "Zero", color=color.new(color.gray, 75))

// 金叉/死叉圆点标记（参考图2风格）
goldenCross = ta.crossover(macdLine, signalLine)
deadCross   = ta.crossunder(macdLine, signalLine)

codex/add-green-and-red-markers-for-crossovers-7z4198
crossPrice = (macdLine + signalLine) / 2.0
plotshape(showCrossDots and goldenCross ? crossPrice : na, title="Golden Cross Dot", style=shape.circle, location=location.absolute, size=size.tiny, color=color.new(color.lime, 0))
plotshape(showCrossDots and deadCross ? crossPrice : na, title="Dead Cross Dot", style=shape.circle, location=location.absolute, size=size.tiny, color=color.new(color.red, 0))

plotshape(showCrossDots and goldenCross ? macdLine : na, title="Golden Cross Dot", style=shape.circle, location=location.absolute, size=size.tiny, color=color.new(color.lime, 0))
plotshape(showCrossDots and deadCross ? macdLine : na, title="Dead Cross Dot", style=shape.circle, location=location.absolute, size=size.tiny, color=color.new(color.red, 0))
main

// 只保留轻背景，不额外画 OB/OS 线和圆点
bgColor = overboughtWarning ? color.new(#1E88E5, 94) : oversoldWarning ? color.new(#EC407A, 94) : na
bgcolor(showBgWarning ? bgColor : na)

// ============================================================================
// Continuous divergence tint drawn directly on MACD line
// ============================================================================
bullDivColor = color.new(#00BCD4, 0)   // 青蓝
bearDivColor = color.new(#C86DD7, 0)   // 紫粉

var line[] divLines = array.new_line()

f_push_line(_ln) =>
    array.push(divLines, _ln)
    if array.size(divLines) > 420
        old = array.shift(divLines)
        line.delete(old)

if bullDiv and bar_index > rightBars + preBars + 1
    startOff = rightBars + preBars
    usablePost = math.min(postBars, rightBars)
    endOff = rightBars - usablePost
    if startOff > endOff
        i = startOff
        while i > endOff
            ln = line.new(
                 x1 = bar_index - i,
                 y1 = macdLine[i],
                 x2 = bar_index - (i - 1),
                 y2 = macdLine[i - 1],
                 xloc = xloc.bar_index,
                 extend = extend.none,
                 color = bullDivColor,
                 width = divLineWidth)
            f_push_line(ln)
            i := i - 1

if bearDiv and bar_index > rightBars + preBars + 1
    startOff = rightBars + preBars
    usablePost = math.min(postBars, rightBars)
    endOff = rightBars - usablePost
    if startOff > endOff
        i = startOff
        while i > endOff
            ln = line.new(
                 x1 = bar_index - i,
                 y1 = macdLine[i],
                 x2 = bar_index - (i - 1),
                 y2 = macdLine[i - 1],
                 xloc = xloc.bar_index,
                 extend = extend.none,
                 color = bearDivColor,
                 width = divLineWidth)
            f_push_line(ln)
            i := i - 1

// ============================================================================
// Alerts
// ============================================================================
alertcondition(overboughtWarning, title="Overbought Warning", message="Signal line is in a dynamic overbought warning zone (early warning).")
alertcondition(oversoldWarning, title="Oversold Warning", message="Signal line is in a dynamic oversold warning zone (early warning).")
alertcondition(bullDiv, title="Bullish Histogram Divergence", message="Bullish MACD histogram divergence detected (early warning).")
alertcondition(bearDiv, title="Bearish Histogram Divergence", message="Bearish MACD histogram divergence detected (early warning).")
